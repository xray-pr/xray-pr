{
  "extensions": [".ts", ".tsx", ".js", ".jsx"],
  "doc_extensions": [],
  "test_file_pattern": "\\.(test|spec)\\.(ts|tsx|js|jsx)$",
  "symbols": {
    "types": "^[+-].*(export\\s+)?(interface|type|class|enum)\\s+(\\w+)",
    "functions": "^[+-].*(export\\s+)?(async\\s+)?function\\s+(\\w+)|^[+-].*(export\\s+)?const\\s+(\\w+)\\s*=\\s*(async\\s+)?\\(",
    "errors": "^[+-].*(class\\s+\\w*Error\\w*|new\\s+Error\\(|throw\\s+new)",
    "tests": "^[+-].*(describe|it|test)\\s*\\(",
    "config": "^[+-].*(interface|type)\\s+\\w*Config\\w*",
    "concurrency": "^[+-].*(new\\s+Worker|Promise\\.all|Promise\\.race|new\\s+SharedArrayBuffer)"
  }
}
