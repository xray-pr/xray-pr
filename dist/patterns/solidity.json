{
  "extensions": [".sol"],
  "doc_extensions": [],
  "test_file_pattern": "\\.t\\.sol$",
  "symbols": {
    "types": "^[+-].*(contract|interface|library|abstract\\s+contract)\\s+(\\w+)",
    "functions": "^[+-].*function\\s+(\\w+)\\s*\\(",
    "errors": "^[+-].*(error\\s+\\w+|revert\\s+\\w+|require\\()",
    "tests": "^[+-].*function\\s+test\\w+",
    "config": "^[+-].*(struct\\s+\\w*Config\\w*|struct\\s+\\w*Params\\w*)",
    "concurrency": ""
  }
}
