{
  "extensions": [".py"],
  "doc_extensions": [],
  "test_file_pattern": "(^|/)test_.*\\.py$|_test\\.py$",
  "symbols": {
    "types": "^[+-].*class\\s+(\\w+)",
    "functions": "^[+-].*def\\s+(\\w+)\\(",
    "errors": "^[+-].*(class\\s+\\w*Error\\w*|class\\s+\\w*Exception\\w*|raise\\s+\\w+)",
    "tests": "^[+-].*(def\\s+test_|@pytest)",
    "config": "^[+-].*class\\s+\\w*Config\\w*",
    "concurrency": "^[+-].*(threading\\.|multiprocessing\\.|asyncio\\.|async\\s+def|await\\s)"
  }
}
